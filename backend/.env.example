PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=change-this-to-another-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# 数据库配置
# DB_TYPE 可选值: sqlite, postgres, mysql (默认: sqlite)
DB_TYPE=sqlite

# SQLite 配置 (当 DB_TYPE=sqlite 时使用)
DATABASE_PATH=./data/monitor.db

# PostgreSQL / MySQL 配置 (当 DB_TYPE=postgres 或 mysql 时使用)
# 方式1: 使用连接字符串
# DATABASE_URL=postgresql://user:password@localhost:5432/cloud_monitor
# DATABASE_URL=mysql://user:password@localhost:3306/cloud_monitor

# 方式2: 使用独立配置项
# DB_HOST=localhost
# DB_PORT=5432  # PostgreSQL 默认 5432, MySQL 默认 3306
# DB_NAME=cloud_monitor
# DB_USER=postgres
# DB_PASS=your_password
# DB_SSL=false  # 是否启用 SSL 连接

# API 密钥加密密钥（32位字符）
ENCRYPTION_KEY=change-this-to-32-char-secret-key

# 邮件告警配置（可选）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=monitor@example.com
